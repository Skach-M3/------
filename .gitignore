# 1. 依赖包 (最重要，绝对不提交)
node_modules/
dist/
dist-ssr/
*.local

# 2. 编译产物与日志
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# 3. 环境变量 (包含 API 密钥等敏感信息)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 4. TypeScript 相关
*.tsbuildinfo

# 5. IDE 与系统文件
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# 6. 测试相关
/tests/unit/coverage/
/tests/e2e/reports/
/tests/e2e/videos/
/tests/e2e/screenshots/

# 7. 打包相关
/unpackage/
